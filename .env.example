# Glote -- required environment variables

# Copy this file to .env and fill in your real values.
# .env is gitignored; this template is not.

# DATABASE_URL: Supabase Postgres connection string (Transaction Pooler).
# Get yours from: Supabase Dashboard -> Connect -> Direct -> Transaction pooler -> URI
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres